<div class="form-container">
    <h2 class="form-title">Dodaj igralca</h2>
<form action="/volleyball/players" method="POST">
  <label for="number">Number:</label>
  <input type="text" id="number" name="number" class="form-input" required>

  <label for="name">Name:</label>
  <input type="text" id="name" name="name" class="form-input" required>

  <label for="position">Position:</label>
  <input type="text" id="position" name="position" class="form-input" required>

  <label for="date_of_birth">Date of birth:</label>
  <input type="date" id="date_of_birth" name="date_of_birth" class="form-input" required>

  <label for="height">Height:</label>
  <input type="text" id="height" name="height" class="form-input" required>

  <label for="spike_reach">Spike reach:</label>
  <input type="text" id="spike_reach" name="spike_reach" class="form-input" required>

  <label for="block_reach">Block reach:</label>
  <input type="text" id="block_reach" name="block_reach" class="form-input" required>

  <label for="head_coach">Head coach:</label>
  <input type="text" id="head_coach" name="head_coach" class="form-input" required>

  <label for="team">Team:</label>
  <input type="text" id="team" name="team" class="form-input" required>

  <input type="submit" value="Submit" class="form-submit">
</form>
</div>